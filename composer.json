{
    "name": "soritune/developers",
    "description": "developers.soritune.com admin tool",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Soritune\\Developers\\": "lib/"
        }
    },
    "autoload-dev": {
